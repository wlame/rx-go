  "info": {
    "contact": {
      "name": "rx-tool",
      "url": "https://github.com/wlame/rx-tool"
    },
    "description": "Regex search + file indexing for large logs. Go port of rx-python.",
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    },
    "title": "rx-tool API",
    "version": "golden-test"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "description": "Returns service status, ripgrep availability, app version, OS info, environment variables, and hook configuration.",
        "operationId": "health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Health check and system introspection",
        "tags": [
          "General"
        ]
      }
    },
    "/v1/compress": {
      "post": {
        "description": "Creates a background task that encodes the file to .zst. Poll /v1/tasks/{id} for progress.",
        "operationId": "compress",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompressRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Compress file to seekable zstd format (background task)",
        "tags": [
          "Operations"
        ]
      }
    },
    "/v1/detectors": {
      "get": {
        "description": "Returns metadata about every registered detector, plus the severity-scale legend.",
        "operationId": "list-detectors",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DetectorsResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "List all available anomaly detectors",
        "tags": [
          "Analysis"
        ]
      }
    },
    "/v1/index": {
      "get": {
        "description": "Returns the cached UnifiedFileIndex, or 404 if no index exists yet.",
        "operationId": "index-get",
        "parameters": [
          {
            "description": "File path to get index for",
            "explode": false,
            "in": "query",
            "name": "path",
            "required": true,
            "schema": {
              "description": "File path to get index for",
              "examples": [
                "/var/log/app.log"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {},
                  "type": "object"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get cached index data for a file",
        "tags": [
          "Indexing"
        ]
      },
      "post": {
        "description": "Creates a background task that indexes the file. Poll /v1/tasks/{id} for progress.",
        "operationId": "index-post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IndexRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TaskResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Build line index for file (background task)",
        "tags": [
          "Operations"
        ]
      }
    },
    "/v1/samples": {
      "get": {
        "description": "Use this endpoint to view actual content around matches from /v1/trace.",
        "operationId": "samples",
        "parameters": [
          {
            "description": "File path to read from",
            "explode": false,
            "in": "query",
            "name": "path",
            "required": true,
            "schema": {
              "description": "File path to read from",
              "examples": [
                "/var/log/app.log"
              ],
              "type": "string"
            }
          },
          {
            "description": "Comma-separated byte offsets or ranges",
            "explode": false,
            "in": "query",
            "name": "offsets",
            "schema": {
              "description": "Comma-separated byte offsets or ranges",
              "examples": [
                "100,200,300"
              ],
              "type": "string"
            }
          },
          {
            "description": "Comma-separated 1-based line numbers or ranges",
            "explode": false,
            "in": "query",
            "name": "lines",
            "schema": {
              "description": "Comma-separated 1-based line numbers or ranges",
              "examples": [
                "100,200-205,-1"
              ],
              "type": "string"
            }
          },
          {
            "description": "Context lines before AND after each offset (-1 = default 3)",
            "explode": false,
            "in": "query",
            "name": "context",
            "schema": {
              "default": -1,
              "description": "Context lines before AND after each offset (-1 = default 3)",
              "examples": [
                3
              ],
              "format": "int64",
              "minimum": -1,
              "type": "integer"
            }
          },
          {
            "description": "Context lines before each offset (-1 = default 3)",
            "explode": false,
            "in": "query",
            "name": "before_context",
            "schema": {
              "default": -1,
              "description": "Context lines before each offset (-1 = default 3)",
              "format": "int64",
              "minimum": -1,
              "type": "integer"
            }
          },
          {
            "description": "Context lines after each offset (-1 = default 3)",
            "explode": false,
            "in": "query",
            "name": "after_context",
            "schema": {
              "default": -1,
              "description": "Context lines after each offset (-1 = default 3)",
              "format": "int64",
              "minimum": -1,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SamplesResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Get context lines around byte offsets or line numbers",
        "tags": [
          "Context"
        ]
      }
