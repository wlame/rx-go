    "/v1/trace": {
      "get": {
        "description": "Uses ripgrep to scan one or more paths for one or more regex patterns, returning match offsets.",
        "operationId": "trace",
        "parameters": [
          {
            "description": "File or directory path(s) to search",
            "explode": false,
            "in": "query",
            "name": "path",
            "required": true,
            "schema": {
              "description": "File or directory path(s) to search",
              "examples": [
                [
                  "/var/log/app.log"
                ]
              ],
              "items": {
                "type": "string"
              },
              "type": [
                "array",
                "null"
              ]
            }
          },
          {
            "description": "Regex pattern(s) to search for",
            "explode": false,
            "in": "query",
            "name": "regexp",
            "required": true,
            "schema": {
              "description": "Regex pattern(s) to search for",
              "examples": [
                [
                  "error"
                ]
              ],
              "items": {
                "type": "string"
              },
              "type": [
                "array",
                "null"
              ]
            }
          },
          {
            "description": "Maximum results to return. 0 = unlimited.",
            "explode": false,
            "in": "query",
            "name": "max_results",
            "schema": {
              "description": "Maximum results to return. 0 = unlimited.",
              "examples": [
                100
              ],
              "format": "int64",
              "minimum": 0,
              "type": "integer"
            }
          },
          {
            "description": "Custom UUID v7 request ID",
            "explode": false,
            "in": "query",
            "name": "request_id",
            "schema": {
              "description": "Custom UUID v7 request ID",
              "examples": [
                "01936c8e-7b2a-7000-8000-000000000001"
              ],
              "type": "string"
            }
          },
          {
            "description": "URL to POST when file scan completes",
            "explode": false,
            "in": "query",
            "name": "hook_on_file",
            "schema": {
              "description": "URL to POST when file scan completes",
              "type": "string"
            }
          },
          {
            "description": "URL to POST per match. Requires max_results.",
            "explode": false,
            "in": "query",
            "name": "hook_on_match",
            "schema": {
              "description": "URL to POST per match. Requires max_results.",
              "type": "string"
            }
          },
          {
            "description": "URL to POST when the whole trace completes",
            "explode": false,
            "in": "query",
            "name": "hook_on_complete",
            "schema": {
              "description": "URL to POST when the whole trace completes",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TraceResponse"
                }
              }
            },
            "description": "OK"
          },
          "default": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            },
            "description": "Error"
          }
        },
        "summary": "Search file for regex patterns (supports multiple patterns)",
        "tags": [
          "Search"
        ]
      }
    },
